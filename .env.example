# Database Configuration
# Replace these values with your actual database credentials

DB_HOST=your-database-host.com
DB_PORT=3307
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# Flask Secret Key (REQUIRED)
# Used for session management and JWT token signing
# Generate a secure key by running: python3 -c "import secrets; print(secrets.token_hex(32))"
# NEVER use the same key across different environments or commit your actual key to version control
SECRET_KEY=your_secret_key_here_generate_a_new_one

# HTTPS Configuration
# Set to 'True' in production when HTTPS is enabled (forces secure cookies)
# Keep as 'False' in development for HTTP localhost access
HTTPS_ENABLED=True_or_False

# CORS Configuration
# Comma-separated list of allowed origins for cross-origin requests
# Leave empty in development to auto-allow localhost
CORS_ALLOWED_ORIGINS=

# Rate Limiting Configuration
# Adjust these values based on your security requirements
# Format: number per time_period (e.g., "5 per 15 minutes", "100 per hour")
RATE_LIMIT_LOGIN=5 per 15 minutes
RATE_LIMIT_REGISTER=3 per hour
RATE_LIMIT_CHANGE_PASSWORD=3 per hour
RATE_LIMIT_ADMIN=30 per minute
RATE_LIMIT_API=100 per minute

# Backup Trigger Whitelist
# Comma-separated list of allowed origins for backup trigger endpoint
BACKUP_ALLOWED_ORIGINS=your_cron_service_origins_here

# ============================================================================
# INTEGRATION CREDENTIALS
# ============================================================================
# Gemini AI API Key (for bill scanning)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Drive (for database backups)
# Get these by running: python scripts/google_drive_auth.py
GOOGLE_DRIVE_CLIENT_ID=your_oauth_client_id_here
GOOGLE_DRIVE_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_DRIVE_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_DRIVE_BACKUP_FOLDER_ID=your_google_drive_backup_folder_id_here
GOOGLE_DRIVE_BILLS_FOLDER_ID=your_google_drive_bills_folder_id_here

# Backup Encryption Password (for password-protected zip files)
# Use a strong, unique password different from your admin password
BACKUP_ENCRYPTION_PASSWORD=your_strong_backup_password_here